{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "jsx": "react-jsx",
    "strict": true,
    "strictFunctionTypes": false,
    "noEmit": true,
    "lib": ["es2020", "dom", "dom.iterable"],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noUnusedLocals": true,
    "resolveJsonModule": true
  },
  "exclude": ["remotion.config.ts"]
}
