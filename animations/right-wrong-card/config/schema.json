{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://full-video-pipeline/animations/right-wrong-card.schema.json",
  "title": "RightWrongCard instance",
  "description": "Per-template schema for right-wrong-card. All TemplateConfig core fields (theme/global/elements/instanceId/$schema) are $ref'd from the global animations.schema.json; extras.* and element.custom.* specific to this template are extended here.",
  "type": "object",
  "additionalProperties": false,
  "required": ["extras"],
  "properties": {
    "$schema": {"type": "string"},
    "instanceId": {"type": "string"},
    "theme": {"$ref": "https://full-video-pipeline/schemas/animations.schema.json#/definitions/theme"},
    "global": {"$ref": "https://full-video-pipeline/schemas/animations.schema.json#/definitions/global"},
    "elements": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["id"],
        "properties": {
          "id": {
            "type": "string",
            "enum": ["left-label", "left-body", "right-label", "right-body", "verdict-stamp"]
          },
          "text": {"type": ["string", "null"]},
          "delay": {"type": ["number", "null"], "minimum": 0, "maximum": 60000},
          "duration": {"type": ["number", "null"], "minimum": 1, "maximum": 60000},
          "easing": {"$ref": "https://full-video-pipeline/schemas/animations.schema.json#/definitions/easingName"},
          "position": {"$ref": "https://full-video-pipeline/schemas/animations.schema.json#/definitions/element/properties/position"},
          "size": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "fontSize": {"type": ["number", "null"], "minimum": 4, "maximum": 1000},
              "scale": {"type": ["number", "null"], "minimum": 0.05, "maximum": 20}
            }
          },
          "color": {"type": ["string", "null"]},
          "hidden": {"type": "boolean", "default": false},
          "custom": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "verdictColor": {"type": ["string", "null"]}
            }
          }
        }
      }
    },
    "extras": {
      "type": "object",
      "additionalProperties": false,
      "required": ["leftIsWinner"],
      "properties": {
        "leftIsWinner": {"type": "boolean"},
        "stampStyle": {"type": "string", "enum": ["stamp", "shake", "glow", "none"], "default": "stamp"},
        "stampGlyph": {"type": "string", "default": ""},
        "stampForce": {"type": "number", "minimum": 0, "maximum": 2, "default": 1},
        "cardPaddingPx": {"type": "number", "minimum": 0, "maximum": 200, "default": 48},
        "cardGapPx": {"type": "number", "minimum": 0, "maximum": 400, "default": 64},
        "cornerRadiusPx": {"type": "number", "minimum": 0, "maximum": 200, "default": 24},
        "bgRgbaAlpha": {"type": "number", "minimum": 0, "maximum": 1, "default": 0.55},
        "loserDesaturate": {"type": "boolean", "default": true},
        "loserShrink": {"type": "number", "minimum": 0.1, "maximum": 1.5, "default": 0.92},
        "winnerGlowWidthPx": {"type": "number", "minimum": 0, "maximum": 100, "default": 24}
      }
    }
  }
}